{
  "name": "@maple-care/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.ts test/",
    "seed": "ts-node prisma/seed.ts",
    "s3:setup": "bash ../../scripts/setup-s3.sh",
    "library:promote": "ts-node scripts/promote-module.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.692.0",
    "@aws-sdk/s3-request-presigner": "^3.692.0",
    "@mux/mux-node": "^9.0.1",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/platform-express": "^10.4.7",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.26.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^5.5.6",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@nestjs/cli": "^10.4.7",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.7",
    "@swc/core": "^1.7.42",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "@types/pdfkit": "^0.13.5",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "unplugin-swc": "^1.5.1",
    "vitest": "^4.1.6"
  }
