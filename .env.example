# Copy to .env and fill in. Never commit real secrets.

# --- Database ---
POSTGRES_USER=maple
POSTGRES_PASSWORD=maple
POSTGRES_DB=maple_care
DATABASE_URL=postgresql://maple:maple@localhost:5432/maple_care

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=4000
API_BASE_URL=http://localhost:4000

# --- Web ---
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Stripe (per-seat subscription billing for operator orgs) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PER_SEAT_ID=

# --- Mux (video) ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=

# --- Email (Resend). Leave blank in dev to log instead of sending. ---
RESEND_API_KEY=
EMAIL_FROM="Maple Care <no-reply@maple.care>"

# --- AWS S3 (file storage; ca-central-1 for PHIPAA / Atlantic residency) ---
AWS_REGION=ca-central-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Default launch jurisdiction. NB | NS | PE | NL | ON ---
DEFAULT_JURISDICTION=NB
