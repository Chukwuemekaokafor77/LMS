# Copy to .env and fill in. Never commit real secrets.
#
# NOTE: dotenv resolves duplicate keys last-wins — a stray empty `KEY=` line
# below a real value silently blanks it (this once 401'd every API auth call
# via a duplicate empty CLERK_SECRET_KEY=). Keep each key exactly once.

# --- Database ---
POSTGRES_USER=maple
POSTGRES_PASSWORD=maple
POSTGRES_DB=maple_care
DATABASE_URL=postgresql://maple:maple@localhost:5432/maple_care

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=4000
API_BASE_URL=http://localhost:4000

# --- Web ---
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Where the web app sends signed-out / "sign in" visitors — the ElderCare app
# (staff enter the Academy via ElderCare's "Training" button, not a login here).
NEXT_PUBLIC_ELDERCARE_APP_URL=

# --- Auth: ElderCare Academy SSO (the only identity source; Clerk is gone) ---
# ElderCare's API base URL, for the /academy/exchange call.
ELDERCARE_API_URL=
# Shared HMAC secret with ElderCare's ACADEMY_EXCHANGE_SECRET (psw repo).
ACADEMY_EXCHANGE_SECRET=
# Signs the Academy's own 8h session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACADEMY_SESSION_SECRET=

# --- Mux (video) ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=

# --- Email (Resend). Leave blank in dev to log instead of sending. ---
RESEND_API_KEY=
EMAIL_FROM="ElderCare Academy <no-reply@example.com>"  # set to the real academy sender domain

# --- AWS S3 (file storage; ca-central-1 for PHIPAA / Atlantic residency) ---
# Local dev without an AWS account: `docker compose up -d minio minio-init`
# then use the MinIO values below (uncomment). The AWS SDK honours
# AWS_ENDPOINT_URL_S3 natively; leave it empty for real AWS.
#   AWS_ENDPOINT_URL_S3=http://s3.localhost.localstack.cloud:9000
#   AWS_S3_BUCKET=maple-care-dev
#   AWS_ACCESS_KEY_ID=minioadmin
#   AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ca-central-1
AWS_ENDPOINT_URL_S3=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Default launch jurisdiction. NB | NS | PE | NL | ON ---
DEFAULT_JURISDICTION=NB
